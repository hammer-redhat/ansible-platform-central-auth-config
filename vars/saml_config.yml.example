---
# Non-secret SAML and gateway settings. Override per environment with inventory,
# -e, or a separate env-specific vars file.
#
# Copy to vars/saml_config.yml (gitignored) and tune. Secrets:
#   - SP private key: vars/vault.yml → vault_saml_sp_private_key (see vars/vault.yml.example)

# --- Platform gateway (shared with LDAP-style playbooks) ---
aap_hostname: "https://aap.example.com"
aap_validate_certs: true

# --- SAML authenticator (gateway) ---
aap_saml_authenticator_name: "My SAML Auth Provider"
aap_saml_authenticator_order: 4
aap_saml_enabled: true
aap_saml_create_objects: false
aap_saml_remove_users: false

# Slug appears in CALLBACK_URL and SSO paths. For an existing authenticator, copy from
# GET /api/gateway/v1/authenticators/<id>/ (field "slug"). New installs: set after first sync if needed.
aap_saml_authenticator_slug: "5dab6034-cd3d-47ff-bea8-c0aa1c9e1887"

aap_saml_callback_url: "{{ (aap_hostname | regex_replace('/+$', '')) }}/api/gateway/social/complete/{{ aap_saml_authenticator_slug }}/"

# IdP endpoints (Keycloak / RH-SSO example)
saml_idp_entity_id: "https://rh-sso.example.com/auth/realms/example"
saml_idp_url: "https://rh-sso.example.com/auth/realms/example/protocol/saml"

# Attribute names from the IdP assertion (match your IdP claim / friendly names)
saml_idp_attr_email: "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress"
saml_idp_attr_first_name: "firstName"
saml_idp_attr_last_name: "lastName"
saml_idp_attr_username: "username"
saml_idp_attr_user_permanent_id: "username"

# Service provider metadata
saml_sp_entity_id: "saml_entity"
saml_sp_extra:
  requestedAuthnContext: false

# Organization / contact metadata (maps to gateway SAML plugin ORG_INFO / contacts)
saml_org_info:
  en-US:
    url: "http://example.com"
    name: "Hammer-SAML"
    displayname: "Hammer SAML"

saml_support_contact:
  givenName: "Chris Hammer"
  emailAddress: "chrhamme@redhat.com"

saml_technical_contact:
  givenName: "Chris Hammer"
  emailAddress: "chrhamme@redhat.com"

