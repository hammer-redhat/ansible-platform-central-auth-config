# Built configuration dict for ansible.platform.authenticator (SP_PRIVATE_KEY supplied in playbook vars)
aap_saml_configuration:
  ADDITIONAL_UNVERIFIED_ARGS: {}
  CALLBACK_URL: "{{ aap_saml_callback_url }}"
  EXTRA_DATA: []
  IDP_ATTR_EMAIL: "{{ saml_idp_attr_email }}"
  IDP_ATTR_FIRST_NAME: "{{ saml_idp_attr_first_name }}"
  IDP_ATTR_LAST_NAME: "{{ saml_idp_attr_last_name }}"
  IDP_ATTR_USERNAME: "{{ saml_idp_attr_username }}"
  IDP_ATTR_USER_PERMANENT_ID: "{{ saml_idp_attr_user_permanent_id }}"
  IDP_ENTITY_ID: "{{ saml_idp_entity_id }}"
  IDP_URL: "{{ saml_idp_url }}"
  IDP_X509_CERT: "{{ saml_idp_x509_cert }}"
  ORG_INFO: "{{ saml_org_info }}"
  SECURITY_CONFIG: {}
  SP_ENTITY_ID: "{{ saml_sp_entity_id }}"
  SP_EXTRA: "{{ saml_sp_extra }}"
  SP_PRIVATE_KEY: "{{ saml_sp_private_key }}"
  SP_PUBLIC_CERT: "{{ saml_sp_public_cert }}"
  SUPPORT_CONTACT: "{{ saml_support_contact }}"
  TECHNICAL_CONTACT: "{{ saml_technical_contact }}"

# --- Authenticator map (allow all) — mirrors UI "mappings" for this authenticator ---
aap_saml_map_allow_name: "all"
aap_saml_map_allow_order: 1
aap_saml_map_allow_revoke: false
aap_saml_map_allow_triggers:
  always: {}
